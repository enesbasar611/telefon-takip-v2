UpdateStr = settings.find(s => s.key === \"currency_last_update\")?.value;\r\n      const lastUpdate = lastUpdateStr ? new Date(lastUpdateStr) : new Date(0);\r\n      const now = new Date();\r\n\r\n      // E\u011fer veri eksikse veya 2 saat ge\u00e7mi\u015fse arka planda sync ba\u015flat\r\n      const isStale = settings.length < 3 || (now.getTime() - lastUpdate.getTime() > 2 * 60 * 60 * 1000);\r\n      if (isStale) {\r\n        // Fire-and-forget: revalidateTag \u00e7a\u011fr\u0131s\u0131 syncAllRates i\u00e7inde yap\u0131l\u0131r\r\n        syncAllRates(shopId).catch(() => { });\r\n      }\r\n\r\n      return {\r\n        usd: parseFloat(settings.find(s => s.key === \"exchange_rate_usd\")?.value || \"45.0\"),\r\n        eur: parseFloat(settings.find(s => s.key === \"exchange_rate_eur\")?.value || \"55.0\"),\r\n        ga: parseFloat(settings.find(s => s.key === \"exchange_rate_ga\")?.value || \"6500\"),\r\n        dealerProfit: parseFloat(settings.find(s => s.key === \"dealer_profit_tl\")?.value || \"200\"),\r\n        customerProfit: parseFloat(settings.find(s => s.key === \"customer_profit_tl\")?.value || \"700\"),\r\n        lastUpdate\r\n      };\r\n    },\r\n    [`rates-${shopId}`],\r\n    { tags: [`rates-${shopId}`, \"rates\"], revalidate: 1800 } // 30 dakika\r\n  )", "is_member_call": false, "source_file": "C:\\Users\\PC\\Desktop\\dukkan-app\\telefon-takip-v2\\telefon-takip-v2\\src\\lib\\actions\\currency-actions.ts", "source_location": "L72"}, {"caller_nid": "actions_currency_actions_getexchangerates", "callee": "unstable_cache", "is_member_call": false, "source_file": "C:\\Users\\PC\\Desktop\\dukkan-app\\telefon-takip-v2\\telefon-takip-v2\\src\\lib\\actions\\currency-actions.ts", "source_location": "L72"}, {"caller_nid": "actions_currency_actions_getcurrentexchangerates", "callee": "getShopId", "is_member_call": false, "source_file": "C:\\Users\\PC\\Desktop\\dukkan-app\\telefon-takip-v2\\telefon-takip-v2\\src\\lib\\actions\\currency-actions.ts", "source_