generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TECHNICIAN
  STAFF
}

enum ServiceStatus {
  PENDING      // Beklemede
  APPROVED     // Onay Bekleyen
  REPAIRING    // Tamirde
  WAITING_PART // Parça Bekliyor
  READY        // Hazır
  DELIVERED    // Teslim Edildi
  CANCELLED    // İptal Edildi
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  DEBT
}

enum ReturnReason {
  PART_FAILURE
  LABOR_ERROR
  CUSTOMER_MISUSE
  CUSTOMER_CANCEL
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  password        String
  role            Role      @default(STAFF)
  commissionRate  Decimal   @default(0) @db.Decimal(5, 2) // Percentage e.g. 10.00%
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignedTickets ServiceTicket[] @relation("AssignedTechnician")
  createdTickets  ServiceTicket[] @relation("CreatedBy")
  transactions    Transaction[]
  sales           Sale[]
  returns         ReturnTicket[]
  inventoryLogs   InventoryLog[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  secondaryPhone String?
  email     String?
  address   String?
  notes     String?
  photo     String?
  type      String   @default("BIREYSEL") // BIREYSEL, KURUMSAL
  isVip     Boolean  @default(false)
  loyaltyPoints Int  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets   ServiceTicket[]
  sales     Sale[]
  debts     Debt[]
}

model ServiceTicket {
  id              String        @id @default(cuid())
  ticketNumber    String        @unique // e.g., SRV-1001
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])

  deviceModel     String
  deviceBrand     String
  imei            String?
  serialNumber    String?
  problemDesc     String
  cosmeticCondition String?
  notes           String?

  status          ServiceStatus @default(PENDING)
  priority        Int           @default(1) // 1: Normal, 2: High, 3: Urgent

  technicianId    String?
  technician      User?         @relation("AssignedTechnician", fields: [technicianId], references: [id])
  createdById     String
  createdBy       User          @relation("CreatedBy", fields: [createdById], references: [id])

  estimatedCost   Decimal       @default(0) @db.Decimal(10, 2)
  actualCost      Decimal       @default(0) @db.Decimal(10, 2)
  overhead        Decimal       @default(0) @db.Decimal(10, 2)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deliveredAt     DateTime?
  warrantyExpiry  DateTime?
  estimatedDeliveryDate DateTime?

  logs               ServiceLog[]
  usedParts          ServiceUsedPart[]
  inventoryMovements InventoryMovement[]
  returns            ReturnTicket[]
}

model ServiceLog {
  id              String        @id @default(cuid())
  ticketId        String
  ticket          ServiceTicket @relation(fields: [ticketId], references: [id])
  message         String
  status          ServiceStatus
  createdAt       DateTime      @default(now())
}

model ServiceUsedPart {
  id              String        @id @default(cuid())
  ticketId        String
  ticket          ServiceTicket @relation(fields: [ticketId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int           @default(1)
  unitPrice       Decimal       @db.Decimal(10, 2)
  costPrice       Decimal       @default(0) @db.Decimal(10, 2)
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
}

model Product {
  id              String    @id @default(cuid())
  sku             String?   @unique
  barcode         String?   @unique
  name            String
  description     String?
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])

  buyPrice        Decimal   @db.Decimal(10, 2)
  sellPrice       Decimal   @db.Decimal(10, 2)
  stock           Int       @default(0)
  criticalStock   Int       @default(5)

  isSecondHand    Boolean   @default(false)
  isChronic       Boolean   @default(false)
  supplierId      String?
  location        String?
  warrantyMonths  Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  movements       InventoryMovement[]
  saleItems       SaleItem[]
  usedInServices  ServiceUsedPart[]
  shortageItems   ShortageItem[]
  deviceInfo      DeviceHubInfo?
  returns         ReturnTicket[]
  inventoryLogs   InventoryLog[]
}

model ReturnTicket {
  id              String        @id @default(cuid())
  ticketNumber    String        @unique // e.g., RET-1001
  serviceTicketId String
  serviceTicket   ServiceTicket @relation(fields: [serviceTicketId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  supplierId      String?
  userId          String
  user            User          @relation(fields: [userId], references: [id])

  returnReason    ReturnReason
  lossAmount      Decimal       @default(0) @db.Decimal(10, 2)
  notes           String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model InventoryLog {
  id              String        @id @default(cuid())
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])

  quantity        Int
  type            String        // SALE, PURCHASE, SERVICE_USE, RETURN_RESTORE, RETURN_JUNK, ADJUSTMENT
  notes           String?

  createdAt       DateTime      @default(now())
}

model DeviceHubInfo {
  id              String    @id @default(cuid())
  productId       String    @unique
  product         Product   @relation(fields: [productId], references: [id])

  imei            String    @unique
  serialNumber    String?
  color           String?
  capacity        String?
  batteryHealth   Int?
  cosmeticScore   Int       @default(10) // 1-10
  condition       String    @default("NEW") // NEW, USED

  expertChecklist Json?     // Diagnostic results

  purchaseDate    DateTime?
  purchasedFrom   String?
  buyBackPrice    Decimal?  @db.Decimal(10, 2)
  buyBackMonths   Int?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ShortageItem {
  id          String   @id @default(cuid())
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  name        String   // Fallback if not linked to a product
  quantity    Int      @default(1)
  notes       String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model InventoryMovement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      // Positive for stock in, negative for stock out
  type        String   // SALE, PURCHASE, SERVICE_USE, ADJUSTMENT
  notes       String?

  serviceTicketId String?
  serviceTicket   ServiceTicket? @relation(fields: [serviceTicketId], references: [id])
  saleId          String?
  sale            Sale?          @relation(fields: [saleId], references: [id])

  createdAt       DateTime @default(now())
}

model Sale {
  id              String        @id @default(cuid())
  saleNumber      String        @unique
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])

  totalAmount     Decimal       @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  finalAmount     Decimal       @db.Decimal(10, 2)

  paymentMethod   PaymentMethod @default(CASH)

  createdAt       DateTime      @default(now())

  items              SaleItem[]
  transaction        Transaction?
  inventoryMovements InventoryMovement[]
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
}

model Transaction {
  id              String          @id @default(cuid())
  type            TransactionType
  amount          Decimal         @db.Decimal(10, 2)
  description     String
  paymentMethod   PaymentMethod   @default(CASH)

  userId          String
  user            User            @relation(fields: [userId], references: [id])

  saleId          String?         @unique
  sale            Sale?           @relation(fields: [saleId], references: [id])

  createdAt       DateTime        @default(now())
}

model Debt {
  id              String    @id @default(cuid())
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  amount          Decimal   @db.Decimal(10, 2)
  remainingAmount Decimal   @db.Decimal(10, 2)
  dueDate         DateTime?
  isPaid          Boolean   @default(false)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases PurchaseOrder[]
}

model PurchaseOrder {
  id              String    @id @default(cuid())
  supplierId      String
  supplier        Supplier  @relation(fields: [supplierId], references: [id])
  totalAmount     Decimal   @db.Decimal(10, 2)
  status          String    // PENDING, COMPLETED, CANCELLED
  createdAt       DateTime  @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
