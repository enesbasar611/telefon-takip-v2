generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Shop {
  id                   String                @id @default(cuid())
  name                 String
  address              String?
  phone                String?
  email                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  isActive             Boolean               @default(true)
  enabledModules       String[]              @default(["SERVICE", "STOCK", "SALE", "FINANCE"])
  industry             String                @default("GENERAL")
  themeConfig          Json?
  isFirstLogin         Boolean               @default(true)
  whatsappSessionId    String?
  agendaEvents         AgendaEvent[]
  attachments          Attachment[]
  categories           Category[]
  customers            Customer[]
  dailySessions        DailySession[]
  debts                Debt[]
  deviceHubInfos       DeviceHubInfo[]
  financeAccounts      FinanceAccount[]
  inventoryLogs        InventoryLog[]
  inventoryMovements   InventoryMovement[]
  notifications        Notification[]
  products             Product[]
  purchaseOrders       PurchaseOrder[]
  purchaseOrderItems   PurchaseOrderItem[]
  receiptSettings      ReceiptSettings[]
  reminders            Reminder[]
  returnTickets        ReturnTicket[]
  sales                Sale[]
  saleItems            SaleItem[]
  serviceLogs          ServiceLog[]
  serviceTickets       ServiceTicket[]
  serviceUsedParts     ServiceUsedPart[]
  settings             Setting[]
  shortageItems        ShortageItem[]
  stockAIAlerts        StockAIAlert[]
  suppliers            Supplier[]
  supplierTransactions SupplierTransaction[]
  transactions         Transaction[]
  users                User[]
}

model RolePermission {
  id         String   @id @default(cuid())
  role       Role     @unique
  canSell    Boolean  @default(false)
  canService Boolean  @default(false)
  canStock   Boolean  @default(false)
  canFinance Boolean  @default(false)
  canDelete  Boolean  @default(false)
  canEdit    Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  password        String?
  role            Role            @default(STAFF)
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  commissionRate  Decimal         @default(0) @db.Decimal(5, 2)
  surname         String?
  phone           String?
  canSell         Boolean         @default(true)
  canService      Boolean         @default(true)
  canStock        Boolean         @default(true)
  canFinance      Boolean         @default(false)
  canDelete       Boolean         @default(false)
  canEdit         Boolean         @default(true)
  shopId          String?
  accounts        Account[]
  closedSessions  DailySession[]  @relation("ClosedBy")
  openedSessions  DailySession[]  @relation("OpenedBy")
  inventoryLogs   InventoryLog[]
  purchaseOrders  PurchaseOrder[]
  reminders       Reminder[]
  returns         ReturnTicket[]
  sales           Sale[]
  createdTickets  ServiceTicket[] @relation("CreatedBy")
  assignedTickets ServiceTicket[] @relation("AssignedTechnician")
  sessions        Session[]
  transactions    Transaction[]
  shop            Shop?           @relation(fields: [shopId], references: [id])
}

model Customer {
  id             String          @id @default(cuid())
  name           String
  phone          String?
  email          String?
  address        String?
  notes          String?
  loyaltyPoints  Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isVip          Boolean         @default(false)
  photo          String?
  secondaryPhone String?
  type           String          @default("BIREYSEL")
  shopId         String
  shop           Shop            @relation(fields: [shopId], references: [id])
  debts          Debt[]
  sales          Sale[]
  tickets        ServiceTicket[]

  @@unique([shopId, phone])
}

model ServiceTicket {
  id                    String              @id @default(cuid())
  ticketNumber          String
  customerId            String
  deviceModel           String
  deviceBrand           String
  imei                  String?
  serialNumber          String?
  problemDesc           String
  notes                 String?
  status                ServiceStatus       @default(PENDING)
  priority              Int                 @default(1)
  technicianId          String?
  createdById           String
  estimatedCost         Decimal             @default(0) @db.Decimal(10, 2)
  actualCost            Decimal             @default(0) @db.Decimal(10, 2)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deliveredAt           DateTime?
  cosmeticCondition     String?
  estimatedDeliveryDate DateTime?
  warrantyExpiry        DateTime?
  overhead              Decimal             @default(0) @db.Decimal(10, 2)
  photos                String[]
  devicePassword        String?
  serviceType           String?
  shopId                String
  attributes            Json?
  inventoryMovements    InventoryMovement[]
  returns               ReturnTicket[]
  logs                  ServiceLog[]
  createdBy             User                @relation("CreatedBy", fields: [createdById], references: [id])
  customer              Customer            @relation(fields: [customerId], references: [id])
  shop                  Shop                @relation(fields: [shopId], references: [id])
  technician            User?               @relation("AssignedTechnician", fields: [technicianId], references: [id])
  usedParts             ServiceUsedPart[]

  @@unique([shopId, ticketNumber])
}

model ServiceLog {
  id        String        @id @default(cuid())
  ticketId  String
  message   String
  status    ServiceStatus
  createdAt DateTime      @default(now())
  shopId    String
  shop      Shop          @relation(fields: [shopId], references: [id])
  ticket    ServiceTicket @relation(fields: [ticketId], references: [id])
}

model ServiceUsedPart {
  id             String        @id @default(cuid())
  ticketId       String
  productId      String
  quantity       Int           @default(1)
  unitPrice      Decimal       @db.Decimal(10, 2)
  costPrice      Decimal       @default(0) @db.Decimal(10, 2)
  costPriceUsd   Decimal?      @db.Decimal(10, 2)
  warrantyMonths Int           @default(1)
  warrantyDays   Int?
  shopId         String
  product        Product       @relation(fields: [productId], references: [id])
  shop           Shop          @relation(fields: [shopId], references: [id])
  ticket         ServiceTicket @relation(fields: [ticketId], references: [id])
}

model Category {
  id            String     @id @default(cuid())
  name          String
  parentId      String?
  order         Int        @default(0)
  shopId        String
  parent        Category?  @relation("SubCategories", fields: [parentId], references: [id])
  subCategories Category[] @relation("SubCategories")
  shop          Shop       @relation(fields: [shopId], references: [id])
  products      Product[]

  @@unique([shopId, name])
}

model Product {
  id             String              @id @default(cuid())
  sku            String?
  barcode        String?
  name           String
  description    String?
  categoryId     String
  buyPrice       Decimal             @db.Decimal(10, 2)
  buyPriceUsd    Decimal?            @db.Decimal(10, 2)
  sellPrice      Decimal             @db.Decimal(10, 2)
  stock          Int                 @default(0)
  criticalStock  Int                 @default(5)
  isSecondHand   Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  isChronic      Boolean             @default(false)
  supplierId     String?
  location       String?
  warrantyMonths Int                 @default(0)
  shopId         String
  attributes     Json?
  deviceInfo     DeviceHubInfo?
  inventoryLogs  InventoryLog[]
  movements      InventoryMovement[]
  category       Category            @relation(fields: [categoryId], references: [id])
  shop           Shop                @relation(fields: [shopId], references: [id])
  supplier       Supplier?           @relation(fields: [supplierId], references: [id])
  purchaseItems  PurchaseOrderItem[]
  returns        ReturnTicket[]
  saleItems      SaleItem[]
  usedInServices ServiceUsedPart[]
  shortageItems  ShortageItem[]
  aiAlerts       StockAIAlert[]

  @@unique([shopId, sku])
  @@unique([shopId, barcode])
}

model StockAIAlert {
  id        String   @id @default(cuid())
  type      String
  message   String
  productId String?
  createdAt DateTime @default(now())
  expiresAt DateTime
  isRead    Boolean  @default(false)
  shopId    String
  product   Product? @relation(fields: [productId], references: [id])
  shop      Shop     @relation(fields: [shopId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  category    String
  title       String
  message     String
  referenceId String?
  status      String?
  isRead      Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
}

model Reminder {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  category    String
  recurrence  String   @default("NONE")
  assignedTo  String?
  creatorId   String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shopId      String
  user        User?    @relation(fields: [assignedTo], references: [id])
  shop        Shop     @relation(fields: [shopId], references: [id])
}

model ReturnTicket {
  id              String        @id @default(cuid())
  ticketNumber    String
  serviceTicketId String
  productId       String
  supplierId      String?
  userId          String
  returnReason    ReturnReason
  lossAmount      Decimal       @default(0) @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  shopId          String
  product         Product       @relation(fields: [productId], references: [id])
  serviceTicket   ServiceTicket @relation(fields: [serviceTicketId], references: [id])
  shop            Shop          @relation(fields: [shopId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@unique([shopId, ticketNumber])
}

model InventoryLog {
  id        String   @id @default(cuid())
  productId String
  userId    String
  quantity  Int
  type      String
  notes     String?
  createdAt DateTime @default(now())
  shopId    String
  product   Product  @relation(fields: [productId], references: [id])
  shop      Shop     @relation(fields: [shopId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model DeviceHubInfo {
  id                   String    @id @default(cuid())
  productId            String    @unique
  imei                 String
  serialNumber         String?
  color                String?
  capacity             String?
  ram                  String?
  storage              String?
  batteryHealth        Int?
  cosmeticScore        Int       @default(10)
  condition            String    @default("NEW")
  expertChecklist      Json?
  purchaseDate         DateTime?
  purchasedFrom        String?
  buyBackPrice         Decimal?  @db.Decimal(10, 2)
  buyBackMonths        Int?
  warrantyEndDate      DateTime?
  sim1ExpirationDate   DateTime?
  sim1NotUsed          Boolean   @default(false)
  sim2ExpirationDate   DateTime?
  sim2NotUsed          Boolean   @default(false)
  sellerName           String?
  sellerTC             String?
  sellerPhone          String?
  sellerIdPhotoUrl     String?
  imeiActivationMonths Int?
  imeiUsedMonths       Int?
  photoUrls            String[]
  invoiceUrl           String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  shopId               String
  product              Product   @relation(fields: [productId], references: [id])
  shop                 Shop      @relation(fields: [shopId], references: [id])

  @@unique([shopId, imei])
}

model ShortageItem {
  id         String   @id @default(cuid())
  productId  String?
  name       String
  quantity   Int      @default(1)
  notes      String?
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  shopId     String
  product    Product? @relation(fields: [productId], references: [id])
  shop       Shop     @relation(fields: [shopId], references: [id])
}

model InventoryMovement {
  id              String         @id @default(cuid())
  productId       String
  quantity        Int
  type            String
  notes           String?
  createdAt       DateTime       @default(now())
  saleId          String?
  serviceTicketId String?
  shopId          String
  product         Product        @relation(fields: [productId], references: [id])
  sale            Sale?          @relation(fields: [saleId], references: [id])
  serviceTicket   ServiceTicket? @relation(fields: [serviceTicketId], references: [id])
  shop            Shop           @relation(fields: [shopId], references: [id])
}

model Sale {
  id                 String              @id @default(cuid())
  saleNumber         String
  customerId         String?
  userId             String
  totalAmount        Decimal             @db.Decimal(10, 2)
  discount           Decimal             @default(0) @db.Decimal(10, 2)
  finalAmount        Decimal             @db.Decimal(10, 2)
  paymentMethod      PaymentMethod       @default(CASH)
  createdAt          DateTime            @default(now())
  shopId             String
  inventoryMovements InventoryMovement[]
  customer           Customer?           @relation(fields: [customerId], references: [id])
  shop               Shop                @relation(fields: [shopId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  items              SaleItem[]
  transaction        Transaction?

  @@unique([shopId, saleNumber])
}

model SaleItem {
  id         String  @id @default(cuid())
  saleId     String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)
  shopId     String
  product    Product @relation(fields: [productId], references: [id])
  sale       Sale    @relation(fields: [saleId], references: [id])
  shop       Shop    @relation(fields: [shopId], references: [id])
}

model Transaction {
  id               String          @id @default(cuid())
  type             TransactionType
  amount           Decimal         @db.Decimal(10, 2)
  description      String
  paymentMethod    PaymentMethod   @default(CASH)
  userId           String
  saleId           String?         @unique
  financeAccountId String?
  dailySessionId   String?
  category         String?
  createdAt        DateTime        @default(now())
  shopId           String
  attachments      Attachment[]
  dailySession     DailySession?   @relation(fields: [dailySessionId], references: [id])
  financeAccount   FinanceAccount? @relation(fields: [financeAccountId], references: [id])
  sale             Sale?           @relation(fields: [saleId], references: [id])
  shop             Shop            @relation(fields: [shopId], references: [id])
  user             User            @relation(fields: [userId], references: [id])
}

model Attachment {
  id            String      @id @default(cuid())
  url           String
  filename      String
  fileType      String
  fileSize      Int
  transactionId String
  createdAt     DateTime    @default(now())
  shopId        String
  shop          Shop        @relation(fields: [shopId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model FinanceAccount {
  id           String        @id @default(cuid())
  name         String
  type         AccountType   @default(CASH)
  balance      Decimal       @default(0) @db.Decimal(12, 2)
  isDefault    Boolean       @default(false)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  shopId       String
  billingDay   Int?
  limit        Decimal?      @db.Decimal(12, 2)
  shop         Shop          @relation(fields: [shopId], references: [id])
  transactions Transaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DailySession {
  id             String        @id @default(cuid())
  date           DateTime      @default(now())
  openingBalance Decimal       @db.Decimal(12, 2)
  closingBalance Decimal?      @db.Decimal(12, 2)
  actualBalance  Decimal?      @db.Decimal(12, 2)
  status         SessionStatus @default(OPEN)
  openedById     String
  closedById     String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  shopId         String
  closedBy       User?         @relation("ClosedBy", fields: [closedById], references: [id])
  openedBy       User          @relation("OpenedBy", fields: [openedById], references: [id])
  shop           Shop          @relation(fields: [shopId], references: [id])
  transactions   Transaction[]
}

model Debt {
  id              String    @id @default(cuid())
  customerId      String
  amount          Decimal   @db.Decimal(10, 2)
  remainingAmount Decimal   @db.Decimal(10, 2)
  dueDate         DateTime?
  isPaid          Boolean   @default(false)
  isTracking      Boolean   @default(false)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  shopId          String
  customer        Customer  @relation(fields: [customerId], references: [id])
  shop            Shop      @relation(fields: [shopId], references: [id])
}

model Supplier {
  id            String                @id @default(cuid())
  name          String
  contact       String?
  phone         String?
  email         String?
  address       String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  balance       Decimal               @default(0) @db.Decimal(12, 2)
  balanceUsd    Decimal               @default(0) @db.Decimal(12, 2)
  category      String?               @default("Genel")
  isApproved    Boolean               @default(false)
  logo          String?
  taxNumber     String?
  taxOffice     String?
  totalShopping Decimal               @default(0) @db.Decimal(12, 2)
  trustScore    Int                   @default(100)
  bankName      String?
  iban          String?
  notes         String?
  shopId        String
  products      Product[]
  purchases     PurchaseOrder[]
  shop          Shop                  @relation(fields: [shopId], references: [id])
  transactions  SupplierTransaction[]
}

model PurchaseOrder {
  id              String                @id @default(cuid())
  supplierId      String
  totalAmount     Decimal               @db.Decimal(12, 2)
  createdAt       DateTime              @default(now())
  description     String?
  discount        Decimal               @default(0) @db.Decimal(12, 2)
  netAmount       Decimal               @default(0) @db.Decimal(12, 2)
  orderNo         String
  paymentMethod   PaymentMethod         @default(CASH)
  paymentStatus   PaymentStatus         @default(UNPAID)
  receivedAt      DateTime?
  responsibleId   String?
  shippingInfo    String?
  trackingNo      String?
  updatedAt       DateTime              @updatedAt
  vatAmount       Decimal               @default(0) @db.Decimal(12, 2)
  status          OrderStatus           @default(PENDING)
  remainingAmount Decimal               @default(0) @db.Decimal(12, 2)
  shopId          String
  responsible     User?                 @relation(fields: [responsibleId], references: [id])
  shop            Shop                  @relation(fields: [shopId], references: [id])
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]
  transactions    SupplierTransaction[]

  @@unique([shopId, orderNo])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  orderId          String
  productId        String?
  name             String
  quantity         Int
  receivedQuantity Int           @default(0)
  buyPrice         Decimal       @db.Decimal(12, 2)
  vatRate          Int           @default(20)
  shopId           String
  buyPriceUsd      Decimal?      @db.Decimal(10, 2)
  order            PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?      @relation(fields: [productId], references: [id])
  shop             Shop          @relation(fields: [shopId], references: [id])
}

model SupplierTransaction {
  id              String          @id @default(cuid())
  supplierId      String
  purchaseOrderId String?
  amount          Decimal         @db.Decimal(12, 2)
  amountUsd       Decimal?        @db.Decimal(12, 2)
  exchangeRate    Decimal?        @db.Decimal(10, 4)
  type            TransactionType
  description     String
  date            DateTime        @default(now())
  shopId          String
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  shop            Shop            @relation(fields: [shopId], references: [id])
  supplier        Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model Setting {
  id     String @id @default(cuid())
  key    String
  value  String
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@unique([shopId, key])
}

model ReceiptSettings {
  id        String   @id
  title     String   @default("BAŞAR TEKNİK")
  subtitle  String   @default("PROFESYONEL TEKNİK SERVİS")
  phone     String   @default("+90 (5xx) xxx xx xx")
  address   String?
  footer    String   @default("Bizi Tercih Ettiğiniz İçin Teşekkürler")
  website   String   @default("v2.basarteknik.com")
  updatedAt DateTime @updatedAt
  terms     String?
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
}

model AgendaEvent {
  id          String          @id @default(cuid())
  title       String
  type        AgendaEventType
  date        DateTime
  category    String?
  amount      Decimal?        @db.Decimal(12, 2)
  assignedTo  String[]
  notes       String?
  isCompleted Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  shopId      String
  shop        Shop            @relation(fields: [shopId], references: [id])

  @@index([shopId, date])
}

enum OrderStatus {
  PENDING
  ON_WAY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum Role {
  SUPER_ADMIN
  SHOP_MANAGER
  ADMIN
  MANAGER
  CASHIER
  STAFF
  TECHNICIAN
  USER
}

enum ServiceStatus {
  PENDING
  APPROVED
  REPAIRING
  WAITING_PART
  READY
  DELIVERED
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  DEBT
}

enum ReturnReason {
  PART_FAILURE
  LABOR_ERROR
  CUSTOMER_MISUSE
  CUSTOMER_CANCEL
}

enum AccountType {
  CASH
  BANK
  POS
  CREDIT_CARD
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum AgendaEventType {
  SERVICE
  PAYMENT
  COLLECTION
  TASK
}

enum IndustryType {
  PHONE_REPAIR
  ELECTRICIAN
  PLUMBING
  COMPUTER_REPAIR
  GROCERY
  CLOTHING
  GENERAL
}

model IndustryTemplate {
  id                String   @id @default(cuid())
  slug              String   @unique
  displayName       String
  sidebarConfig     Json
  whatsappTemplates Json
  serviceFields     Json
  dashboardStats    Json     @default("[]")
  primaryColor      String   @default("#6366f1")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

