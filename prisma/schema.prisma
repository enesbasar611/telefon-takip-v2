generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                   String                 @id @default(cuid())
  name                 String
  address              String?
  phone                String?
  email                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  enabledModules       String[]               @default(["SERVICE", "STOCK", "SALE", "FINANCE", "EFATURA"])
  industry             String                 @default("GENERAL")
  themeConfig          Json?
  isFirstLogin         Boolean                @default(true)
  whatsappSessionId    String?
  isActive             Boolean                @default(true)
  taxNumber            String?
  taxOffice            String?
  companyName          String?
  companyAddress       String?
  companyCity          String?                @default("İSTANBUL")
  companyDistrict      String?
  website              String?                @default("basarteknik.tech")
  isCourierEnabled     Boolean                @default(true)
  isEInvoiceEnabled    Boolean                @default(true)
  isFinanceEnabled     Boolean                @default(true)
  isServiceEnabled     Boolean                @default(true)
  isStockEnabled       Boolean                @default(true)
  logoUrl              String?
  agendaEvents         AgendaEvent[]
  attachments          Attachment[]
  auditLogs            AuditLog[]
  categories           Category[]
  customers            Customer[]
  dailySessions        DailySession[]
  debts                Debt[]
  deviceHubInfos       DeviceHubInfo[]
  edmIncomingInvoices  EDMIncomingInvoice[]
  edmInvoices          EDMInvoice[]
  edmInvoiceLines      EDMInvoiceLine[]
  edmSettings          EDMSettings?
  financeAccounts      FinanceAccount[]
  hiddenAgendaItems    HiddenAgendaItem[]
  inventoryLogs        InventoryLog[]
  inventoryMovements   InventoryMovement[]
  monthlyArchives      MonthlyStaffArchive[]
  notifications        Notification[]
  milestones           PerformanceMilestone[]
  products             Product[]
  purchaseOrders       PurchaseOrder[]
  purchaseOrderItems   PurchaseOrderItem[]
  receiptSettings      ReceiptSettings[]
  reminders            Reminder[]
  returnTickets        ReturnTicket[]
  sales                Sale[]
  saleItems            SaleItem[]
  serviceLogs          ServiceLog[]
  serviceTickets       ServiceTicket[]
  serviceUsedParts     ServiceUsedPart[]
  settings             Setting[]
  shortageItems        ShortageItem[]
  staffCommissions     StaffCommission[]
  staffExpenses        StaffExpense[]
  stockAIAlerts        StockAIAlert[]
  suppliers            Supplier[]
  supplierTransactions SupplierTransaction[]
  transactions         Transaction[]
  users                User[]
  leaveRequests        LeaveRequest[]
  whatsAppTemplates    WhatsAppTemplate[]
}

model RolePermission {
  id         String   @id @default(cuid())
  role       Role     @unique
  canSell    Boolean  @default(false)
  canService Boolean  @default(false)
  canStock   Boolean  @default(false)
  canFinance Boolean  @default(false)
  canDelete  Boolean  @default(false)
  canEdit    Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

model User {
  id                   String                @id @default(cuid())
  name                 String?
  email                String                @unique
  password             String?
  role                 Role                  @default(STAFF)
  emailVerified        DateTime?
  image                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  commissionRate       Decimal               @default(0) @db.Decimal(12, 2)
  surname              String?
  phone                String?
  canSell              Boolean               @default(true)
  canService           Boolean               @default(true)
  canStock             Boolean               @default(true)
  canFinance           Boolean               @default(false)
  canDelete            Boolean               @default(false)
  canEdit              Boolean               @default(true)
  shopId               String?
  isApproved           Boolean               @default(false)
  browserNotificationsEnabled Boolean        @default(false)
  verificationCode     String?
  lastVerificationSent DateTime?
  verificationAttempts Int                   @default(0)
  dashboardLayout      Json?
  points               Int                   @default(0)
  baseSalary           Decimal?              @default(0) @db.Decimal(12, 2)
  salaryCurrency       String                @default("TRY")
  serviceCommissionAmount Decimal?              @default(0) @db.Decimal(12, 2)
  accounts             Account[]
  auditLogs            AuditLog[]
  closedSessions       DailySession[]        @relation("ClosedBy")
  openedSessions       DailySession[]        @relation("OpenedBy")
  inventoryLogs        InventoryLog[]
  monthlyArchives      MonthlyStaffArchive[]
  purchaseOrders       PurchaseOrder[]
  reminders            Reminder[]
  returns              ReturnTicket[]
  sales                Sale[]
  createdTickets       ServiceTicket[]       @relation("CreatedBy")
  assignedTickets      ServiceTicket[]       @relation("AssignedTechnician")
  sessions             Session[]
  shortageTasks        ShortageItem[]        @relation("ShortageAssignment")
  staffCommissions     StaffCommission[]
  staffExpenses        StaffExpense[]
  transactions         Transaction[]
  shop                 Shop?                 @relation(fields: [shopId], references: [id])
  leaveRequests        LeaveRequest[]
  approvedCommissions  StaffCommission[]     @relation("CommissionApprover")
  approvedLeaves       LeaveRequest[]        @relation("LeaveApprover")
}

model Customer {
  id             String          @id @default(cuid())
  name           String
  phone          String?
  email          String?
  address        String?
  notes          String?
  loyaltyPoints  Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isVip          Boolean         @default(false)
  photo          String?
  secondaryPhone String?
  type           String          @default("BIREYSEL")
  shopId         String
  balance        Decimal         @default(0) @db.Decimal(12, 2)
  balanceUsd     Decimal         @default(0) @db.Decimal(12, 2)
  taxNumber      String?
  taxOffice      String?
  isEInvoiceUser Boolean?        @default(false)
  shop           Shop            @relation(fields: [shopId], references: [id])
  debts          Debt[]
  edmInvoices    EDMInvoice[]
  returns        ReturnTicket[]
  sales          Sale[]
  tickets        ServiceTicket[]
  shortageItems  ShortageItem[]
  transactions   Transaction[]

  @@unique([shopId, phone])
  @@index([shopId, taxNumber])
}

model ServiceTicket {
  id                    String              @id @default(cuid())
  ticketNumber          String
  customerId            String
  deviceModel           String
  deviceBrand           String
  imei                  String?
  serialNumber          String?
  problemDesc           String
  notes                 String?
  status                ServiceStatus       @default(PENDING)
  priority              Int                 @default(1)
  technicianId          String?
  createdById           String?
  estimatedCost         Decimal             @default(0) @db.Decimal(10, 2)
  actualCost            Decimal             @default(0) @db.Decimal(10, 2)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deliveredAt           DateTime?
  cosmeticCondition     String?
  estimatedDeliveryDate DateTime?
  warrantyExpiry        DateTime?
  overhead              Decimal             @default(0) @db.Decimal(10, 2)
  photos                String[]
  devicePassword        String?
  serviceType           String?
  shopId                String
  attributes            Json?
  edmInvoice            EDMInvoice?
  inventoryMovements    InventoryMovement[]
  returns               ReturnTicket[]
  logs                  ServiceLog[]
  createdBy             User?               @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  customer              Customer            @relation(fields: [customerId], references: [id])
  shop                  Shop                @relation(fields: [shopId], references: [id])
  technician            User?               @relation("AssignedTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  usedParts             ServiceUsedPart[]

  @@unique([shopId, ticketNumber])
  @@index([shopId, status])
  @@index([shopId, createdAt])
  @@index([shopId, warrantyExpiry])
}

model ServiceLog {
  id        String        @id @default(cuid())
  ticketId  String
  message   String
  status    ServiceStatus
  createdAt DateTime      @default(now())
  shopId    String
  shop      Shop          @relation(fields: [shopId], references: [id])
  ticket    ServiceTicket @relation(fields: [ticketId], references: [id])
}

model ServiceUsedPart {
  id             String        @id @default(cuid())
  ticketId       String
  productId      String
  quantity       Int           @default(1)
  unitPrice      Decimal       @db.Decimal(10, 2)
  costPrice      Decimal       @default(0) @db.Decimal(10, 2)
  costPriceUsd   Decimal?      @db.Decimal(10, 2)
  warrantyMonths Int           @default(1)
  warrantyDays   Int?
  shopId         String
  product        Product       @relation(fields: [productId], references: [id])
  shop           Shop          @relation(fields: [shopId], references: [id])
  ticket         ServiceTicket @relation(fields: [ticketId], references: [id])
}

model Category {
  id            String     @id @default(cuid())
  name          String
  parentId      String?
  order         Int        @default(0)
  shopId        String
  parent        Category?  @relation("SubCategories", fields: [parentId], references: [id])
  subCategories Category[] @relation("SubCategories")
  shop          Shop       @relation(fields: [shopId], references: [id])
  products      Product[]

  @@unique([shopId, name])
  @@index([shopId, parentId])
  @@index([shopId, order])
}

model Product {
  id               String              @id @default(cuid())
  sku              String?
  barcode          String?
  name             String
  description      String?
  categoryId       String
  buyPrice         Decimal             @db.Decimal(10, 2)
  buyPriceUsd      Decimal?            @db.Decimal(10, 2)
  sellPrice        Decimal             @db.Decimal(10, 2)
  sellPriceUsd     Decimal?            @db.Decimal(10, 2)
  stock            Int                 @default(0)
  criticalStock    Int                 @default(1)
  isSecondHand     Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  isChronic        Boolean             @default(false)
  supplierId       String?
  location         String?
  warrantyMonths   Int                 @default(0)
  shopId           String
  attributes       Json?
  hideFromShortage Boolean             @default(false)
  deviceInfo       DeviceHubInfo?
  inventoryLogs    InventoryLog[]
  movements        InventoryMovement[]
  category         Category            @relation(fields: [categoryId], references: [id])
  shop             Shop                @relation(fields: [shopId], references: [id])
  supplier         Supplier?           @relation(fields: [supplierId], references: [id])
  purchaseItems    PurchaseOrderItem[]
  returns          ReturnTicket[]
  saleItems        SaleItem[]
  usedInServices   ServiceUsedPart[]
  shortageItems    ShortageItem[]
  aiAlerts         StockAIAlert[]

  @@unique([shopId, sku])
  @@unique([shopId, barcode])
  @@index([shopId, categoryId])
  @@index([shopId, stock])
  @@index([shopId, createdAt])
}

model StockAIAlert {
  id        String   @id @default(cuid())
  type      String
  message   String
  productId String?
  createdAt DateTime @default(now())
  expiresAt DateTime
  isRead    Boolean  @default(false)
  shopId    String
  product   Product? @relation(fields: [productId], references: [id])
  shop      Shop     @relation(fields: [shopId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  category    String
  title       String
  message     String
  referenceId String?
  status      String?
  isRead      Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  snoozedUntil DateTime?
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
}

model Reminder {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  category    String
  recurrence  String   @default("NONE")
  assignedTo  String?
  creatorId   String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shopId      String
  user        User?    @relation(fields: [assignedTo], references: [id])
  shop        Shop     @relation(fields: [shopId], references: [id])
}

model ReturnTicket {
  id                 String              @id @default(cuid())
  ticketNumber       String
  serviceTicketId    String?
  productId          String?
  supplierId         String?
  userId             String?
  returnReason       ReturnReason?
  lossAmount         Decimal             @default(0) @db.Decimal(10, 2)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  shopId             String
  customerId         String?
  debtId             String?
  quantity           Int                 @default(1)
  refundAmount       Decimal?            @db.Decimal(10, 2)
  refundCurrency     String?             @default("TRY")
  restockProduct     Boolean             @default(true)
  returnStatus       ReturnStatus        @default(PENDING)
  saleId             String?
  sourceType         String              @default("SERVICE")
  inventoryMovements InventoryMovement[]
  customer           Customer?           @relation(fields: [customerId], references: [id])
  product            Product?            @relation(fields: [productId], references: [id])
  serviceTicket      ServiceTicket?      @relation(fields: [serviceTicketId], references: [id])
  shop               Shop                @relation(fields: [shopId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  shortageItems      ShortageItem[]

  @@unique([shopId, ticketNumber])
}

model InventoryLog {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  quantity  Int
  type      String
  notes     String?
  createdAt DateTime @default(now())
  shopId    String
  product   Product  @relation(fields: [productId], references: [id])
  shop      Shop     @relation(fields: [shopId], references: [id])
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model DeviceHubInfo {
  id                   String    @id @default(cuid())
  productId            String    @unique
  imei                 String
  serialNumber         String?
  color                String?
  capacity             String?
  ram                  String?
  storage              String?
  batteryHealth        Int?
  cosmeticScore        Int       @default(10)
  condition            String    @default("NEW")
  expertChecklist      Json?
  purchaseDate         DateTime?
  purchasedFrom        String?
  buyBackPrice         Decimal?  @db.Decimal(10, 2)
  buyBackMonths        Int?
  warrantyEndDate      DateTime?
  sim1ExpirationDate   DateTime?
  sim1NotUsed          Boolean   @default(false)
  sim2ExpirationDate   DateTime?
  sim2NotUsed          Boolean   @default(false)
  sellerName           String?
  sellerTC             String?
  sellerPhone          String?
  sellerIdPhotoUrl     String?
  imeiActivationMonths Int?
  imeiUsedMonths       Int?
  photoUrls            String[]
  invoiceUrl           String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  shopId               String
  product              Product   @relation(fields: [productId], references: [id])
  shop                 Shop      @relation(fields: [shopId], references: [id])

  @@unique([shopId, imei])
}

model ShortageItem {
  id             String        @id @default(cuid())
  productId      String?
  name           String
  quantity       Int           @default(1)
  notes          String?
  isResolved     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  shopId         String
  assignedToId   String?
  customerId     String?
  isTaken        Boolean       @default(false)
  requesterName  String?
  requesterPhone String?
  takenAt        DateTime?
  supplierId     String?
  returnTicketId String?
  assignedTo     User?         @relation("ShortageAssignment", fields: [assignedToId], references: [id])
  customer       Customer?     @relation(fields: [customerId], references: [id])
  product        Product?      @relation(fields: [productId], references: [id])
  returnTicket   ReturnTicket? @relation(fields: [returnTicketId], references: [id])
  shop           Shop          @relation(fields: [shopId], references: [id])
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
}

model InventoryMovement {
  id              String         @id @default(cuid())
  productId       String
  quantity        Int
  type            String
  notes           String?
  createdAt       DateTime       @default(now())
  saleId          String?
  serviceTicketId String?
  shopId          String
  supplierId      String?
  debtId          String?
  returnTicketId  String?
  debt            Debt?          @relation(fields: [debtId], references: [id])
  product         Product        @relation(fields: [productId], references: [id])
  returnTicket    ReturnTicket?  @relation(fields: [returnTicketId], references: [id])
  sale            Sale?          @relation(fields: [saleId], references: [id])
  serviceTicket   ServiceTicket? @relation(fields: [serviceTicketId], references: [id])
  shop            Shop           @relation(fields: [shopId], references: [id])
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
}

model Sale {
  id                 String              @id @default(cuid())
  saleNumber         String
  customerId         String?
  userId             String?
  totalAmount        Decimal             @db.Decimal(10, 2)
  discount           Decimal             @default(0) @db.Decimal(10, 2)
  finalAmount        Decimal             @db.Decimal(10, 2)
  paymentMethod      PaymentMethod       @default(CASH)
  createdAt          DateTime            @default(now())
  shopId             String
  debt               Debt?
  edmInvoice         EDMInvoice?
  inventoryMovements InventoryMovement[]
  customer           Customer?           @relation(fields: [customerId], references: [id])
  shop               Shop                @relation(fields: [shopId], references: [id])
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  items              SaleItem[]
  transaction        Transaction?

  @@unique([shopId, saleNumber])
}

model SaleItem {
  id         String  @id @default(cuid())
  saleId     String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)
  shopId     String
  product    Product @relation(fields: [productId], references: [id])
  sale       Sale    @relation(fields: [saleId], references: [id])
  shop       Shop    @relation(fields: [shopId], references: [id])
}

model Transaction {
  id               String          @id @default(cuid())
  type             TransactionType
  amount           Decimal         @db.Decimal(10, 2)
  currency         String          @default("TRY")
  description      String
  paymentMethod    PaymentMethod   @default(CASH)
  userId           String?
  saleId           String?         @unique
  debtId           String?
  financeAccountId String?
  dailySessionId   String?
  category         String?
  createdAt        DateTime        @default(now())
  shopId           String
  customerId       String?
  runningBalance   Decimal?        @db.Decimal(12, 2)
  supplierId       String?
  attachments      Attachment[]
  customer         Customer?       @relation(fields: [customerId], references: [id])
  dailySession     DailySession?   @relation(fields: [dailySessionId], references: [id])
  debt             Debt?           @relation(fields: [debtId], references: [id])
  financeAccount   FinanceAccount? @relation(fields: [financeAccountId], references: [id])
  sale             Sale?           @relation(fields: [saleId], references: [id])
  shop             Shop            @relation(fields: [shopId], references: [id])
  supplier         Supplier?       @relation("SupplierToTransaction", fields: [supplierId], references: [id])
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([createdAt])
  @@index([category])
  @@index([customerId])
  @@index([debtId])
  @@index([financeAccountId])
}

model Attachment {
  id            String      @id @default(cuid())
  url           String
  filename      String
  fileType      String
  fileSize      Int
  transactionId String
  createdAt     DateTime    @default(now())
  shopId        String
  shop          Shop        @relation(fields: [shopId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model FinanceAccount {
  id               String        @id @default(cuid())
  name             String
  type             AccountType   @default(CASH)
  balance          Decimal       @default(0) @db.Decimal(12, 2)
  isDefault        Boolean       @default(false)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  shopId           String
  billingDay       Int?
  limit            Decimal?      @db.Decimal(12, 2)
  availableBalance Decimal?      @db.Decimal(12, 2)
  initialBalance   Decimal       @default(0) @db.Decimal(12, 2)
  shop             Shop          @relation(fields: [shopId], references: [id])
  transactions     Transaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DailySession {
  id             String        @id @default(cuid())
  date           DateTime      @default(now())
  openingBalance Decimal       @db.Decimal(12, 2)
  closingBalance Decimal?      @db.Decimal(12, 2)
  actualBalance  Decimal?      @db.Decimal(12, 2)
  status         SessionStatus @default(OPEN)
  openedById     String?
  closedById     String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  shopId         String
  closedBy       User?         @relation("ClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  openedBy       User?         @relation("OpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  shop           Shop          @relation(fields: [shopId], references: [id])
  transactions   Transaction[]
}

model Debt {
  id                 String              @id @default(cuid())
  customerId         String
  amount             Decimal             @db.Decimal(10, 2)
  remainingAmount    Decimal             @db.Decimal(10, 2)
  dueDate            DateTime?
  isPaid             Boolean             @default(false)
  isTracking         Boolean             @default(false)
  description        String?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  shopId             String
  currency           String              @default("TRY")
  exchangeRate       Decimal?            @db.Decimal(10, 4)
  saleId             String?             @unique
  customer           Customer            @relation(fields: [customerId], references: [id])
  sale               Sale?               @relation(fields: [saleId], references: [id])
  shop               Shop                @relation(fields: [shopId], references: [id])
  inventoryMovements InventoryMovement[]
  transactions       Transaction[]
}

model Supplier {
  id                  String                @id @default(cuid())
  name                String
  contact             String?
  phone               String?
  email               String?
  address             String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  balance             Decimal               @default(0) @db.Decimal(12, 2)
  balanceUsd          Decimal               @default(0) @db.Decimal(12, 2)
  category            String?               @default("Genel")
  isApproved          Boolean               @default(false)
  logo                String?
  taxNumber           String?
  taxOffice           String?
  totalShopping       Decimal               @default(0) @db.Decimal(12, 2)
  trustScore          Int                   @default(100)
  bankName            String?
  iban                String?
  notes               String?
  shopId              String
  inventoryMovements  InventoryMovement[]
  products            Product[]
  purchases           PurchaseOrder[]
  returns             ReturnTicket[]
  shortageItems       ShortageItem[]
  shop                Shop                  @relation(fields: [shopId], references: [id])
  SupplierTransaction SupplierTransaction[]
  transactions        Transaction[]         @relation("SupplierToTransaction")
}

model PurchaseOrder {
  id              String                @id @default(cuid())
  supplierId      String
  totalAmount     Decimal               @db.Decimal(12, 2)
  createdAt       DateTime              @default(now())
  description     String?
  discount        Decimal               @default(0) @db.Decimal(12, 2)
  netAmount       Decimal               @default(0) @db.Decimal(12, 2)
  orderNo         String
  paymentMethod   PaymentMethod         @default(CASH)
  paymentStatus   PaymentStatus         @default(UNPAID)
  receivedAt      DateTime?
  responsibleId   String?
  shippingInfo    String?
  trackingNo      String?
  updatedAt       DateTime              @updatedAt
  vatAmount       Decimal               @default(0) @db.Decimal(12, 2)
  status          OrderStatus           @default(PENDING)
  remainingAmount Decimal               @default(0) @db.Decimal(12, 2)
  shopId          String
  responsible     User?                 @relation(fields: [responsibleId], references: [id])
  shop            Shop                  @relation(fields: [shopId], references: [id])
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]
  transactions    SupplierTransaction[]

  @@unique([shopId, orderNo])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  orderId          String
  productId        String?
  name             String
  quantity         Int
  receivedQuantity Int           @default(0)
  buyPrice         Decimal       @db.Decimal(12, 2)
  vatRate          Int           @default(20)
  shopId           String
  buyPriceUsd      Decimal?      @db.Decimal(10, 2)
  order            PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?      @relation(fields: [productId], references: [id])
  shop             Shop          @relation(fields: [shopId], references: [id])
}

model SupplierTransaction {
  id              String          @id @default(cuid())
  supplierId      String
  purchaseOrderId String?
  amount          Decimal         @db.Decimal(12, 2)
  amountUsd       Decimal?        @db.Decimal(12, 2)
  exchangeRate    Decimal?        @db.Decimal(10, 4)
  type            TransactionType
  description     String
  date            DateTime        @default(now())
  shopId          String
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  shop            Shop            @relation(fields: [shopId], references: [id])
  supplier        Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model Setting {
  id     String @id @default(cuid())
  key    String
  value  String
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@unique([shopId, key])
}

model WhatsAppTemplate {
  id        String   @id @default(cuid())
  name      String   // e.g., "SERVICE_READY", "STOCK_CRITICAL"
  content   String   @db.Text
  category  String   @default("GENERAL")
  variables String[] // e.g., ["customerName", "productName"]
  isActive  Boolean  @default(true)
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, name])
}

model ReceiptSettings {
  id        String   @id
  title     String   @default("BAŞAR TEKNİK")
  subtitle  String   @default("PROFESYONEL TEKNİK SERVİS")
  phone     String   @default("+90 (5xx) xxx xx xx")
  address   String?
  footer    String   @default("Bizi Tercih Ettiğiniz İçin Teşekkürler")
  website   String   @default("basarteknik.tech")
  updatedAt DateTime @updatedAt
  terms     String?
  shopId    String
  logoUrl   String?
  paperSize String   @default("72mm")
  footer2   String?  @default("Yine Bekleriz")
  shop      Shop     @relation(fields: [shopId], references: [id])
}

model AgendaEvent {
  id          String          @id @default(cuid())
  title       String
  type        AgendaEventType
  date        DateTime
  category    String?
  amount      Decimal?        @db.Decimal(12, 2)
  assignedTo  String[]
  notes       String?
  isCompleted Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  shopId      String
  shop        Shop            @relation(fields: [shopId], references: [id])

  @@index([shopId, date])
}

model HiddenAgendaItem {
  id        String   @id @default(cuid())
  sourceId  String
  shopId    String
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, sourceId])
}

model IndustryTemplate {
  id                String   @id @default(cuid())
  slug              String   @unique
  displayName       String
  sidebarConfig     Json
  whatsappTemplates Json
  serviceFields     Json
  dashboardStats    Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  primaryColor      String   @default("#6366f1")
}

model EDMInvoice {
  id              String           @id @default(cuid())
  shopId          String
  uuid            String
  invoiceId       String
  type            EDMInvoiceType   @default(EARCHIVE)
  status          EDMInvoiceStatus @default(DRAFT)
  customerId      String?
  saleId          String?          @unique
  serviceTicketId String?          @unique
  totalAmount     Decimal          @db.Decimal(12, 2)
  subtotal        Decimal          @db.Decimal(12, 2)
  taxTotal        Decimal          @db.Decimal(12, 2)
  currency        String           @default("TRY")
  issueDate       DateTime
  note            String?
  viewUrl         String?
  edmError        String?
  cancelledAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        Customer?        @relation(fields: [customerId], references: [id])
  sale            Sale?            @relation(fields: [saleId], references: [id])
  serviceTicket   ServiceTicket?   @relation(fields: [serviceTicketId], references: [id])
  shop             Shop             @relation(fields: [shopId], references: [id])
  lines           EDMInvoiceLine[]

  @@unique([shopId, uuid])
  @@index([shopId, status])
  @@index([shopId, issueDate])
}

model EDMInvoiceLine {
  id         String     @id @default(cuid())
  invoiceId  String
  shopId     String
  name       String
  quantity   Int
  unitPrice  Decimal    @db.Decimal(12, 2)
  totalPrice Decimal    @db.Decimal(12, 2)
  vatRate    Int        @default(18)
  vatAmount  Decimal    @db.Decimal(12, 2)
  unitCode   String     @default("C62")
  invoice    EDMInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shop       Shop       @relation(fields: [shopId], references: [id])
}

model EDMIncomingInvoice {
  id          String   @id @default(cuid())
  shopId      String
  uuid        String
  invoiceId   String
  senderVkn   String
  senderName  String
  receiverVkn String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("TRY")
  status      String
  issueDate   DateTime
  envelopeId  String?
  isRead      Boolean  @default(false)
  syncedAt    DateTime @default(now())
  shop        Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, uuid])
  @@index([shopId, issueDate])
}

model EDMSettings {
  id                String   @id @default(cuid())
  shopId            String   @unique
  environment       String   @default("TEST")
  senderVkn         String?
  senderName        String?
  senderAddress     String?
  senderCity        String?  @default("İstanbul")
  senderDistrict    String?
  senderTaxOffice   String?
  username          String?
  passwordEncrypted String?
  apiUrl            String?
  registrationUrl   String?
  edmActive         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model TenantSettings {
  id                     String   @id @default(cuid())
  tenant_id              String   @unique
  company_vkn            String
  edm_username           String
  edm_password_encrypted String
  integration_code       String?
  integration_company_id Int?
  is_active              Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Invoices {
  id             String    @id @default(cuid())
  tenant_id      String
  direction      String
  invoice_number String?
  ettn           String
  receiver_title String?
  receiver_vkn   String?
  invoice_date   DateTime?
  payable_amount Decimal   @db.Decimal(12, 2)
  status         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenant_id, direction])
  @@index([tenant_id, ettn])
  @@index([tenant_id, invoice_date])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  shopId     String
  action     String
  entityType String
  entityId   String?
  entityName String?
  message    String
  details    Json?
  createdAt  DateTime @default(now())
  shop       Shop     @relation(fields: [shopId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([userId])
  @@index([createdAt])
}

model StaffCommission {
  id          String           @id @default(cuid())
  userId      String
  amount      Decimal          @db.Decimal(12, 2)
  description String
  status      CommissionStatus @default(PENDING)
  type        String           @default("SERVICE")
  referenceId String?
  approvedAt   DateTime?
  approvedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  shopId       String
  shop         Shop             @relation(fields: [shopId], references: [id])
  user         User             @relation(fields: [userId], references: [id])
  approvedBy   User?            @relation("CommissionApprover", fields: [approvedById], references: [id])

  @@index([userId, status])
  @@index([shopId, createdAt])
}

model StaffExpense {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal  @db.Decimal(12, 2)
  description String
  type        String   @default("ADVANCE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model PerformanceMilestone {
  id          String   @id @default(cuid())
  role        Role
  targetType  String
  targetValue Decimal  @db.Decimal(12, 2)
  bonusAmount Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId, role])
}

model MonthlyStaffArchive {
  id               String   @id @default(cuid())
  userId           String?
  staffName        String?
  staffEmail       String?
  period           String
  baseSalary       Decimal  @db.Decimal(12, 2)
  totalCommissions Decimal  @db.Decimal(12, 2)
  totalExpenses    Decimal  @db.Decimal(12, 2)
  netPayout        Decimal  @db.Decimal(12, 2)
  closedAt         DateTime @default(now())
  shopId           String
  metadata         Json?
  shop             Shop     @relation(fields: [shopId], references: [id])
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([userId, period])
  @@index([shopId, period])
}

model LeaveRequest {
  id        String      @id @default(cuid())
  userId    String
  shopId    String
  type      LeaveType
  status    LeaveStatus @default(PENDING)
  startDate DateTime
  endDate      DateTime
  note         String?
  approvedById String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  shop         Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy   User?        @relation("LeaveApprover", fields: [approvedById], references: [id])

  @@index([shopId])
  @@index([userId])
}

enum LeaveType {
  ANNUAL
  DAILY
  PAID
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  ON_WAY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  STAFF
  TECHNICIAN
  SUPER_ADMIN
  SHOP_MANAGER
  USER
  COURIER
}

enum ServiceStatus {
  PENDING
  APPROVED
  REPAIRING
  WAITING_PART
  READY
  DELIVERED
  CANCELLED
}

enum TransactionType {
